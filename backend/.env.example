# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auto_report

# Metabase
METABASE_BASE_URL=https://metabase-dev.shargethailand.com
METABASE_API_KEY=your_api_key_here

# AWS S3
AWS_S3_BUCKET=sharge-reports
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret

# AWS SES
SES_SENDER_EMAIL=reports@shargethailand.com

# App
APP_ENV=development
