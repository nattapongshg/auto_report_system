# ═══════════════════════════════════════════════════════════════════
# Auto Report System — environment template
#
# Copy to .env and fill in real values. NEVER commit .env.
#
# Two environments only:
#   local laptop → APP_ENV=development (docker-compose, test SMTP box)
#   prod EC2     → APP_ENV=production  (real SMTP, real Metabase)
# ═══════════════════════════════════════════════════════════════════

# ─── App ───────────────────────────────────────────────────────────
# One of: production | development
APP_ENV=production

# ─── Postgres (docker-compose internal) ────────────────────────────
# User/DB have safe defaults in docker-compose.yml — only PASSWORD is required.
POSTGRES_USER=postgres
POSTGRES_DB=auto_report
POSTGRES_PASSWORD=                        # REQUIRED — generate: openssl rand -base64 24

# ─── PostgREST auth ────────────────────────────────────────────────
# JWT_SECRET must be ≥ 32 chars. SERVICE_JWT + ANON_JWT are signed with it.
#   1) openssl rand -hex 48                         → JWT_SECRET
#   2) python deploy/gen-jwt.py "$JWT_SECRET"       → prints both JWTs
JWT_SECRET=                               # REQUIRED
SERVICE_JWT=                              # REQUIRED
ANON_JWT=                                 # REQUIRED

# ─── Metabase ──────────────────────────────────────────────────────
# Requires VPC/VPN access to metabase.shargethailand.com.
METABASE_BASE_URL=https://metabase.shargethailand.com
METABASE_API_KEY=                         # REQUIRED

# ─── SMTP (Office 365) ─────────────────────────────────────────────
# Tenant admin must enable SMTP AUTH for SMTP_USER, otherwise sends fail with
# "535 5.7.139 SmtpClientAuthentication is disabled".
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@shargemgmt.com
SMTP_PASSWORD=                            # REQUIRED
SMTP_FROM_EMAIL=REVERSHARGER <support@shargemgmt.com>

# Local dev tip: use a test SMTP account and/or override email_recipients on the
# locations you're testing with so real customers don't receive dry-run emails.

# ─── Caddy (reverse proxy + TLS) ───────────────────────────────────
# SITE_ADDRESS options:
#   :80                             → LAN/VPN only, no TLS
#   auto-report.sharge.internal     → internal hostname, supply your own cert
#   auto-report.shargethailand.com  → public FQDN, Caddy auto-issues via ACME
SITE_ADDRESS=auto-report.sharge.internal
ACME_EMAIL=ops@shargemgmt.com             # only used when SITE_ADDRESS is a public FQDN
