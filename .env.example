# Copy to .env and fill in real values. NEVER commit .env.

# ─── Postgres (docker-compose) ─────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-in-production
POSTGRES_DB=auto_report

# ─── PostgREST auth ────────────────────────────────────────────
# JWT secret ≥ 32 chars. Use: openssl rand -hex 48
JWT_SECRET=replace-with-openssl-rand-hex-48-result-here

# Generate these with: python deploy/gen-jwt.py "$JWT_SECRET"
SERVICE_JWT=paste-service-role-jwt
ANON_JWT=paste-anon-jwt

# ─── Metabase ──────────────────────────────────────────────────
METABASE_BASE_URL=https://metabase.shargethailand.com
METABASE_API_KEY=mb_replace_me

# ─── SMTP (Office 365) ─────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@shargemgmt.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=REVERSHARGER <support@shargemgmt.com>

# ─── Caddy ─────────────────────────────────────────────────────
# Public hostname or `:80` for LAN-only. Set to a real domain to auto-issue TLS.
SITE_ADDRESS=auto-report.sharge.internal
ACME_EMAIL=ops@shargemgmt.com

# ─── App ───────────────────────────────────────────────────────
APP_ENV=production
